.env
.env.*
!.env.auth.example
!.env.production.example
__pycache__/
*.py[cod]
.DS_Store
Thumbs.db
node_modules/
*.log

# Docker entrypoint symlink/junction — recreated at container start
auth/public/api

# Archived / one-off scripts kept locally only
unused/

# Level solve JSON trees — distribute via solves.zip instead
solves/
!solves.zip

# Solver enumeration output (logs, streams, audits) — see data/solver-runs/README.txt
data/solver-runs/*
!data/solver-runs/.gitkeep
!data/solver-runs/README.txt

# Per-user progress JSON (server-side saves)
data/progress/users/
