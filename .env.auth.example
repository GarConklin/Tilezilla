# Tilezilla auth service (docker-compose.auth.yml)

AUTH_PORT=3001
APP_BASE_URL=http://localhost:3000

# tilegame MySQL (same DB as game stack)
MYSQL_HOST=garz-puzzle-mysql
MYSQL_PORT=3306
MYSQL_USER=tilegame
MYSQL_PASSWORD=tilegame_dev
MYSQL_DATABASE=tilegame

APP_FROM_EMAIL=words@skifflakegames.com
APP_ADMIN_EMAIL=gar@hotmail.ca

# Direct SMTP — Tilezilla VPS → mail.skifflakegames.com (separate server)
SMTP_ENABLED=true
SMTP_HOST=mail.skifflakegames.com
SMTP_PORT=587
SMTP_TLS=none
