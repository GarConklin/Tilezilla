# Copy to .env.auth and adjust for your server.
# Used by: docker compose -f docker-compose.auth.yml --env-file .env.auth up -d

AUTH_PORT=8081
APP_BASE_URL=http://localhost:8081
APP_NAME=Tilezilla
APP_FROM_EMAIL=words@skifflakegames.com
APP_ADMIN_EMAIL=gar@hotmail.ca

# Words Online shared user DB (on words_network)
WORDS_DB_HOST=words_db
WORDS_DB_USER=wordsgame
WORDS_DB_PASS=wordspass123
WORDS_DB_NAME=WordsOnline

# Tilezilla game DB (optional — tile_profiles, progress)
MYSQL_HOST=garz-puzzle-mysql
MYSQL_USER=tilegame
MYSQL_PASSWORD=tilegame_dev
MYSQL_DATABASE=tilegame
