# Tilezilla auth service (docker-compose.auth.yml)
# Words Online stack is mail relay only (words_network + words_mailserver).

AUTH_PORT=8081
APP_BASE_URL=http://localhost:8081

# tilegame MySQL (same DB as game stack — garz-puzzle-mysql on dev)
MYSQL_HOST=garz-puzzle-mysql
MYSQL_PORT=3306
MYSQL_USER=tilegame
MYSQL_PASSWORD=tilegame_dev
MYSQL_DATABASE=tilegame

APP_FROM_EMAIL=words@skifflakegames.com
APP_ADMIN_EMAIL=gar@hotmail.ca
