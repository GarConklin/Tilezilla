# Copy to .env.production on the Ubuntu server (do not commit).
# Used by: docker compose -f docker-compose.production.yml --env-file .env.production

# Public URL — verification emails and auth redirects use this.
APP_BASE_URL=https://tile.skifflakegames.com

# Gateway bind (host nginx proxies to this).
GATEWAY_BIND=127.0.0.1:3000

# Auth direct bind (optional local access; game auth also works via gateway /auth/*).
AUTH_BIND=127.0.0.1:3001

# MySQL — change passwords before going live.
MYSQL_ROOT_PASSWORD=CHANGE_ME_root
MYSQL_DATABASE=tilegame
MYSQL_USER=tilegame
MYSQL_PASSWORD=CHANGE_ME_tilegame

# Outbound mail (From: header — must be allowed by your mail relay).
APP_FROM_EMAIL=words@skifflakegames.com
APP_ADMIN_EMAIL=gar@hotmail.ca
APP_NAME=Tilezilla

# SMTP — EmailNotifier.php connects directly (Tilezilla VPS → mail.skifflakegames.com).
SMTP_ENABLED=true
SMTP_HOST=mail.skifflakegames.com
SMTP_PORT=587
# SMTP_TLS=none
# SMTP_USER=
# SMTP_PASS=
